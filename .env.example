# Application
NODE_ENV=development
PORT=3000
ENABLE_SWAGGER=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=youruser
DB_PASSWORD=yourpassword
DB_DATABASE=campamento
DB_SSL=false

# Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRATION=1d

# CORS
ALLOWED_ORIGINS=https://yourfrontend.com,https://www.yourfrontend.com

# File Storage
UPLOADS_PATH=/path/to/uploads
MAX_FILE_SIZE=5242880  # 5MB in bytes

# Rate Limiting
THROTTLE_TTL=60000  # 1 minute
THROTTLE_LIMIT=100  # Max 100 requests per TTL